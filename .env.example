# Azure OpenAI — resource: oai-wedding-website-mci (mci-wedding-website RG, eastus)
# No API key needed — uses DefaultAzureCredential (Managed Identity in prod, az login locally)
AZURE_OPENAI_ENDPOINT=https://oai-wedding-website-mci-ffcdb.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4-1-mini
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure AI Search — resource: search-wedding-mci (mci-wedding-website RG, eastus)
# No API key needed — uses DefaultAzureCredential
AZURE_SEARCH_ENDPOINT=https://search-wedding-mci.search.windows.net
AZURE_SEARCH_INDEX_NAME=vows-vedas-chatbot

# Azure Communication Services — resource: gets-email-service (rg-gets-chatbot, global/AME)
# No connection string needed — uses DefaultAzureCredential
AZURE_COMMUNICATION_ENDPOINT=https://gets-email-service.unitedstates.communication.azure.com
AZURE_SENDER_ADDRESS=DoNotReply@vowsandvedas.com

# Azure Application Insights — resource: appi-vows-prod-eus-001 (mci-wedding-website RG, eastus)
# Copy the full connection string from: Portal → App Insights → Overview → Connection String
# Used for the Vows & Vedas enquiry analytics workbook (workbook/vows-vedas-analytics.workbook)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Google reCAPTCHA v3 (forms anti-spam) — create keys at https://www.google.com/recaptcha/admin
# Site key is public (sent to the browser); secret key is server-only.
# When RECAPTCHA_SECRET_KEY is unset, server-side verification is skipped (form still works).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Azure Key Vault — kv-vows-prod-eus-001 (mci-wedding-website RG, eastus)
# All secrets go here. Code reads via DefaultAzureCredential — no plain-text values anywhere.
AZURE_KEY_VAULT_URI=https://kv-vows-prod-eus-001.vault.azure.net/

# Local dev: run `az login` — DefaultAzureCredential will pick up your CLI session.
# Required RBAC on your identity (request via PIM or ask nikhil.arora@wearemci.com):
#   - Cognitive Services OpenAI User  → oai-wedding-website-mci
#   - Search Index Data Reader        → search-wedding-mci
#   - Contributor                     → gets-email-service
#   - Key Vault Secrets User          → kv-vows-prod-eus-001
#   - Monitoring Metrics Publisher    → appi-vows-prod-eus-001  (for telemetry write)
