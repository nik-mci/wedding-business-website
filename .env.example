# Azure OpenAI — resource: oai-wedding-website-mci (mci-wedding-website RG, eastus)
AZURE_OPENAI_ENDPOINT=https://oai-wedding-website-mci-ffcdb.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4-1-mini
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure AI Search — resource: search-wedding-mci (mci-wedding-website RG, eastus)
AZURE_SEARCH_ENDPOINT=https://search-wedding-mci.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=vows-vedas-chatbot

# Azure Email Communication Services
AZURE_COMMUNICATION_CONNECTION_STRING=
AZURE_SENDER_ADDRESS=DoNotReply@vowsandvedas.com

# Google reCAPTCHA v3 (forms anti-spam) — create keys at https://www.google.com/recaptcha/admin
# Site key is public (sent to the browser); secret key is server-only.
# When RECAPTCHA_SECRET_KEY is unset, server-side verification is skipped (form still works).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
